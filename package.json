{
  "name": "casesift-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check .",
    "lhci": "lhci autorun",
    "lhci:mobile": "lhci autorun --config=lighthouserc.mobile.cjs",
    "pa11y": "pa11y-ci",
    "validate:structured-data": "node scripts/validate-structured-data.mjs",
    "validate:robots": "node scripts/validate-robots.mjs",
    "validate:sitemap": "node scripts/validate-sitemap.mjs",
    "smoke": "node scripts/smoke.mjs",
    "links:check": "lychee --config .lychee.toml https://localhost:3000"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "lucide-react": "^0.460.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^1.7.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "pa11y-ci": "^3.1.0",
    "prettier": "^3.4.0",
    "schema-dts": "^1.1.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wait-on": "^8.0.1"
  }
}
